# Application
APP_PORT=8089
APP_ENV=development

# PostgreSQL
DATABASE_URL=postgres://konfig:konfig@localhost:5432/settings_db
DATABASE_MAX_CONNECTIONS=10

# Auth0
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_AUDIENCE=https://api.konfig.example.com

# Redis (Phase 2)
REDIS_URL=redis://localhost:6379
CACHE_TTL_SECS=300
